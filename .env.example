# ============================================================
#  PREMIUM OTT SUBSCRIPTION SHOP BOT  -  Environment Config
# ============================================================
# Copy this file to ".env" (or ".env.development.local") and fill it in.

# Get this from @BotFather
BOT_TOKEN=123456:ABC-YourBotTokenHere

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net
DB_NAME=ott_shop_bot

# Comma-separated Telegram numeric user IDs of admins.
# Get yours from @userinfobot
ADMIN_IDS=123456789,987654321

# ------------------------------------------------------------
# NOTE: Everything else is configured live from inside the bot:
#   /admin  ->  Settings
#     - Shop name & welcome text
#     - Support username
#     - USDT TRC20 / BEP20 addresses
#     - Stars-per-dollar rate
#     - Referral reward
#     - Force-join channel
#     - Premium / custom emoji IDs
# No code changes or restarts required.
# ------------------------------------------------------------
